from PySide6.QtWidgets import (
    QApplication, QWidget, QVBoxLayout, QTableView, QDialog,
    QVBoxLayout as QV, QTextEdit, QPushButton
)
from PySide6.QtCore import Qt, QAbstractTableModel, QModelIndex
from PySide6.QtWidgets import QHeaderView
import sys


class BatchTableModel(QAbstractTableModel):
    def __init__(self, batches):
        super().__init__()
        self.batches = batches
        self.headers = ["GRN", "Batch", "Quantity", "Unit Cost", "Expiry", "Store", "Received"]

    def rowCount(self, parent=None):
        return len(self.batches)

    def columnCount(self, parent=None):
        return 7

    def data(self, index, role=Qt.DisplayRole):
        if not index.isValid():
            return None
        batch = self.batches[index.row()]
        col = index.column()
        if role == Qt.DisplayRole:
            return batch[col]
        return None

    def headerData(self, section, orientation, role=Qt.DisplayRole):
        if role == Qt.DisplayRole and orientation == Qt.Horizontal:
            return self.headers[section]
        return None


class BatchListPage(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Test Batches")
        layout = QVBoxLayout(self)

        self.table = QTableView()
        self.table.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        layout.addWidget(self.table)

        data = [
            ["GRN1", "B001", 10, 1.23, "2026-01-01", "Main", "2025-06-01"],
            ["GRN2", "B002", 5, 2.34, "2026-02-01", "Main", "2025-06-02"],
        ]
        self.model = BatchTableModel(data)
        self.table.setModel(self.model)

        self.table.doubleClicked.connect(self._open_batch_details)

    def _open_batch_details(self, index: QModelIndex):
        row = index.row()
        batch = self.model.batches[row]
        details = "\n".join(f"{h}: {v}" for h, v in zip(self.model.headers, batch))

        dlg = QDialog(self)
        dlg.setWindowTitle("Batch Details")
        lay = QV(dlg)
        text = QTextEdit()
        text.setReadOnly(True)
        text.setText(details)
        lay.addWidget(text)
        btn = QPushButton("Close")
        btn.clicked.connect(dlg.accept)
        lay.addWidget(btn)
        dlg.exec()


if __name__ == "__main__":
    app = QApplication(sys.argv)
    w = BatchListPage()
    w.resize(800, 400)
    w.show()
    sys.exit(app.exec())
